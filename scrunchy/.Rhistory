library(Seurat)
knitr::opts_chunk$set(
echo = TRUE,
out.width = "100%"
)
knitr::include_graphics("figures/method-overview.svg")
library(scrunchy)
library(SingleCellExperiment)
library(dplyr)
library(purrr)
fsce_tidy <- purrr::reduce(
list(
tidy_dims(fsce_small) %>%
select(cell_id, starts_with("UMAP"), -experiment),
tidy_coldata(fsce_small),
tidy_logcounts(fsce_small[c("Uracil_45", "riboG_44"), , ]) %>%
select(-experiment)
),
left_join,
by = "cell_id"
)
library(SingleCellExperiment)
# `rnaseq` stores RNA info
fsce_small[["rnaseq"]]
knitr::opts_chunk$set(
collapse = TRUE,
comment = "#>",
fig.path = "man/figures/README-",
out.width = "100%"
)
plot_grid(
plot_activity(fsce_tidy, Normal_45, leiden_cluster) + theme(legend.position = "none") + xlim(0, 3),
plot_activity(fsce_tidy, Uracil_45, leiden_cluster) + theme(legend.position = "none") + xlim(0, 3),
plot_activity(fsce_tidy, riboG_44, leiden_cluster) + theme(legend.position = "none") + xlim(0, 3),
plot_activity(fsce_tidy, Abasic_46, leiden_cluster) + theme(legend.position = "none") + xlim(0, 3),
labels = c("A", "B", "C", "D"),
nrow = 2, ncol = 2, axis = "b", align = "v"
)
q()
